<%- include('partials/head') %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Source+Serif+4:wght@400;600&family=Inter:wght@400;600&family=Merriweather:wght@400;700&family=Lato:wght@400;700&family=Montserrat:wght@400;600&display=swap" rel="stylesheet">
<div class="reader-titlebar">
  <a class="titlebar-back" href="/" title="Back to shelf">‹</a>
  <% if (book.cover_path) { %><img class="titlebar-cover" src="/media/book/<%= book.id %>/cover" alt=""><% } %>
  <div class="titlebar-text">
    <div class="titlebar-book"><%= book.title %></div>
    <div class="titlebar-chapter"><%= chapter.title %></div>
  </div>
  <div class="titlebar-nav">
    <% if (prevIdx !== null) { %><a class="chapter-arrow" href="/book/<%= book.slug %>/<%= prevIdx %>" title="Previous chapter">‹</a><% } else { %><span class="chapter-arrow disabled">‹</span><% } %>
    <% if (nextIdx !== null) { %><a class="chapter-arrow" href="/book/<%= book.slug %>/<%= nextIdx %>" title="Next chapter">›</a><% } else { %><span class="chapter-arrow disabled">›</span><% } %>
  </div>
</div>

<article id="chapter-content" class="chapter-content"><%- chapter.content_html %></article>

<div class="chapter-end">
  <% if (nextIdx !== null) { %>
    <a class="next-chapter-btn" href="/book/<%= book.slug %>/<%= nextIdx %>">NEXT CHAPTER</a>
  <% } %>
  <section class="chapter-comments">
    <div class="comments-header">
      <h2 id="chapter-comments-title"><%= chapterCommentCount %> Comments</h2>
      <select id="chapter-sort" class="sort-select" aria-label="Sort comments">
        <option value="top">Top</option>
        <option value="new">Newest</option>
      </select>
    </div>
    <div id="chapter-comment-form"></div>
    <div id="chapter-comment-list" class="comment-list"></div>
  </section>
</div>

<div id="panel-backdrop" class="panel-backdrop" hidden></div>
<aside id="comment-panel" class="comment-panel" hidden aria-label="Paragraph comments">
  <div class="panel-header">
    <span id="panel-title">Comments</span>
    <select id="panel-sort" class="sort-select" aria-label="Sort comments">
      <option value="top">Top</option>
      <option value="new">Newest</option>
    </select>
    <button id="panel-close" class="panel-close" aria-label="Close">×</button>
  </div>
  <div id="panel-form"></div>
  <div id="panel-list" class="comment-list"></div>
</aside>

<div id="font-panel" class="font-panel" hidden>
  <div class="font-panel-label">Font</div>
  <div class="font-grid">
    <button type="button" class="font-choice" data-font="opensans">Opensans</button>
    <button type="button" class="font-choice" data-font="sourceserif">Source serif</button>
    <button type="button" class="font-choice" data-font="inter">Inter</button>
    <button type="button" class="font-choice" data-font="merriweather">Merriweather</button>
    <button type="button" class="font-choice" data-font="lato">Lato</button>
    <button type="button" class="font-choice" data-font="montserrat">Montserrat</button>
  </div>
  <div class="font-panel-row">
    <span class="font-panel-label">Text size</span>
    <div class="stepper">
      <button type="button" id="size-minus" class="stepper-btn" aria-label="Smaller text">−</button>
      <span id="size-value" class="stepper-value">18</span>
      <button type="button" id="size-plus" class="stepper-btn" aria-label="Larger text">+</button>
    </div>
  </div>
  <div class="font-panel-row">
    <span class="font-panel-label">Line height</span>
    <div class="stepper">
      <button type="button" id="lh-minus" class="stepper-btn" aria-label="Tighter lines">−</button>
      <span id="lh-value" class="stepper-value">30</span>
      <button type="button" id="lh-plus" class="stepper-btn" aria-label="Looser lines">+</button>
    </div>
  </div>
  <div class="font-panel-label">Contrast</div>
  <div class="contrast-row">
    <button type="button" id="contrast-normal" class="contrast-btn" aria-label="Normal contrast">✓</button>
    <button type="button" id="contrast-high" class="contrast-btn contrast-a" aria-label="High contrast">A</button>
  </div>
  <div class="font-panel-label">Color</div>
  <div class="theme-row">
    <button type="button" class="theme-btn" data-theme="dark">Dark</button>
    <button type="button" class="theme-btn" data-theme="light">Light</button>
    <button type="button" class="theme-btn" data-theme="sepia">Sepia</button>
  </div>
  <button type="button" id="font-reset" class="font-reset">RESET</button>
</div>

<div class="reader-bottombar">
  <button type="button" id="badges-toggle" class="bar-btn" aria-pressed="true" title="Show/hide paragraph comments">P</button>
  <button type="button" id="font-toggle" class="bar-btn" aria-expanded="false" title="Font options">tT</button>
  <select id="toc-select" class="sort-select toc-select" aria-label="Table of contents">
    <% for (const item of toc) { %>
      <option value="/book/<%= book.slug %>/<%= item.idx %>" <%= item.idx === chapter.idx ? 'selected' : '' %>><%= item.title %></option>
    <% } %>
  </select>
  <% if (prevIdx !== null) { %><a class="chapter-arrow" href="/book/<%= book.slug %>/<%= prevIdx %>">‹ Prev</a><% } else { %><span class="chapter-arrow disabled">‹ Prev</span><% } %>
  <% if (nextIdx !== null) { %><a class="chapter-arrow" href="/book/<%= book.slug %>/<%= nextIdx %>">Next ›</a><% } else { %><span class="chapter-arrow disabled">Next ›</span><% } %>
</div>

<script>
  window.__READER__ = {
    chapterId: <%= chapter.id %>,
    badgeCounts: <%- JSON.stringify(badgeCounts) %>,
    user: <%- JSON.stringify(user ? { id: user.id, role: user.role } : null) %>
  };
</script>
<script src="/js/reader.js"></script>
<%- include('partials/footer') %>
