<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <script>
    try {
      var themePref = JSON.parse(localStorage.getItem('bf-reader-settings') || '{}').theme;
      if (themePref === 'light' || themePref === 'sepia') document.documentElement.className = 'theme-' + themePref;
    } catch (e) { /* default dark */ }
  </script>
  <style>
    /* Painted before app.css arrives — no white flash between pages */
    html { background: #0e0e11; color: #d8d8dc; }
    html.theme-light { background: #f4f4f6; color: #2c2c31; }
    html.theme-sepia { background: #f3e9d2; color: #4a3b26; }
  </style>
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#17171c">
</head>
<body>
<nav class="nav">
  <a class="nav-brand" href="/">📚 BookFriends</a>
  <div class="nav-right">
    <% if (user) { %>
      <% if (user.role === 'owner') { %>
        <a class="btn btn-small" href="/upload">Upload</a>
        <a class="btn btn-small btn-ghost" href="/users">Users</a>
      <% } %>
      <a class="nav-bell" href="/notifications" title="Notifications">🔔<% if (unseenNotifs > 0) { %><span class="bell-badge"><%= unseenNotifs > 9 ? '9+' : unseenNotifs %></span><% } %></a>
      <a class="nav-user" href="/settings" title="Settings"><%= user.display_name || user.email %></a>
      <form method="post" action="/logout" class="inline-form"><button class="btn btn-small btn-ghost" type="submit">Log out</button></form>
    <% } else { %>
      <a class="btn btn-small btn-ghost" href="/login">Log in</a>
      <a class="btn btn-small" href="/register">Register</a>
    <% } %>
  </div>
</nav>
<main class="main">
