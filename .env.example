# Email that gets the owner role on registration (only the owner can upload books)
OWNER_EMAIL=you@example.com
# Long random string for session cookies, e.g. `openssl rand -hex 32`
SESSION_SECRET=change-me
PORT=3000
NODE_ENV=development
# All mutable state (SQLite DB, extracted book images, covers) lives here
DATA_DIR=./data
# Max EPUB upload size in MB. Parsing buffers the file in memory, so keep this
# modest on small hosts (e.g. 100 on a 256 MB instance).
MAX_EPUB_MB=200
# Optional: enables the "Continue with Google" button (see README "Google login").
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxxxxx
# Optional: lets an off-site machine download the newest scripts/backup.js
# archive from /backup/download?token=... (see README "Backups").
# Long random string, e.g. `openssl rand -hex 32`; unset = route disabled.
# BACKUP_TOKEN=change-me
# Where scripts/backup.js writes archives (default: sibling of DATA_DIR).
# BACKUP_DIR=./backups
